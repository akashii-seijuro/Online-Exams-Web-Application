# ClassPulse production environment example.
# Copy these keys into your hosting provider environment settings.
# Do not commit real secrets or production connection strings.

# Backend
DATABASE_URL=
REDIS_URL=
JWT_SECRET=
JWT_REFRESH_SECRET=
PORT=
NODE_ENV=production
CLIENT_URL=

# Optional: required only when using image upload.
# Server can start without these; POST /api/v1/upload/image returns a setup error if missing.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: required only when using AI PDF import.
# Server can start without this; POST /api/v1/quizzes/import-pdf returns a setup error if missing.
GEMINI_API_KEY=

# Frontend build-time variables
VITE_API_URL=
VITE_WS_URL=

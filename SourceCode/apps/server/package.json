{
  "name": "@classpulse/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema src/prisma/schema.prisma"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@prisma/client": "^5.0.0",
    "@socket.io/redis-adapter": "^8.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.1",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.0.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.14.0",
    "prisma": "^5.0.0",
    "sanitize-html": "^2.0.0",
    "socket.io": "^4.0.0",
    "streamifier": "^0.1.1",
    "winston": "^3.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/compression": "^1.7.0",
    "@types/cookie-parser": "^1.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/pdfkit": "^0.13.0",
    "@types/sanitize-html": "^2.0.0",
    "@types/streamifier": "^0.1.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
